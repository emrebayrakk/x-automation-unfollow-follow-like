{
  "name": "x-otomasyon",
  "version": "1.0.0",
  "description": "X (Twitter) tarayici otomasyonu - otomatik begeni ve takipten cikma (Playwright)",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "start": "node server.js",
    "desktop": "electron .",
    "dist": "electron-builder --win",
    "setup": "playwright install chromium"
  },
  "dependencies": {
    "express": "^4.19.2",
    "gender-detection-from-name": "^1.11.4",
    "playwright": "^1.48.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.emrebayrak.xotomasyon",
    "productName": "X Otomasyon",
    "directories": { "output": "release" },
    "files": [
      "**/*",
      "!user-data/**",
      "!settings.json",
      "!daily-stats.json",
      "!docs/**",
      "!release/**",
      "!_shot.mjs"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "X-Otomasyon-Setup-${version}.${ext}"
    }
  }
}
